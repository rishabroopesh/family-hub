# PostgreSQL
POSTGRES_DB=familyhub
POSTGRES_USER=familyhub
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Django
DJANGO_SECRET_KEY=CHANGE_ME_RANDOM_50_CHAR_STRING
ALLOWED_HOSTS=*
DEBUG=0

# Google OAuth (for Classroom API)
# Get these from console.cloud.google.com
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
# Set this to your Unraid server IP
GOOGLE_REDIRECT_URI=http://192.168.1.100:8000/api/v1/auth/google/callback/

# Celery / Redis
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
